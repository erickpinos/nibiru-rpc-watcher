# Neon Postgres connection string
DATABASE_URL=postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require

# Nibiru archive node EVM RPC
RPC_URL=https://evm-rpc.archive.nibiru.fi

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polling config
POLL_INTERVAL_MS=30000
STALL_THRESHOLD_CHECKS=5
